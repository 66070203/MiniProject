# ScamGuard Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
API_URL=http://localhost:8000

# MLflow
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=scamguard_spam_detection

# Database
DATABASE_URL=sqlite:///./scamguard.db

# Model
MODEL_PATH=models/best_model.pkl
MODEL_VERSION=1.0.0

# Groq LLM (Two-Stage Hybrid) — สมัครฟรีได้ที่ https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
